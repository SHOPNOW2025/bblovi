rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == "contact@bloovi.media" && isEmailVerified()) ||
        (request.auth.token.email == "tech@thebloom.media" && isEmailVerified()) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == "admin")
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'company'] &&
             data.email == request.auth.token.email;
    }

    function isValidCompany(data) {
      return data.keys().hasAll(['name', 'email']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category', 'desc', 'image']) &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string &&
             data.desc is string &&
             data.image is string;
    }

    function isValidSiteContent(data) {
      return data.keys().hasAll(['key', 'value', 'type']) &&
             data.key is string && data.key.size() <= 100 &&
             data.value is string &&
             (data.keys().hasAny(['color']) ? data.color is string : true) &&
             data.type in ['text', 'image', 'rich-text'];
    }

    function isValidPricingPlan(data) {
      return data.keys().hasAll(['name', 'price', 'features', 'order']) &&
             data.name is string &&
             data.price is string &&
             data.features is list &&
             data.order is number;
    }

    // --- Collections ---

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow create: if isSignedIn() && isOwner(uid) && isValidUser(incoming());
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['email', 'role', 'companyId'])
      );
      // Admin only can change roles
      allow update: if isAdmin() && isValidUser(incoming());
    }

    match /companies/{companyId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidCompany(incoming());
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteContent/{contentId} {
      allow read: if true; // Publicly readable for CMS
      allow write: if isAdmin() && isValidSiteContent(incoming());
    }

    match /pricingPlans/{planId} {
      allow read: if true;
      allow write: if isAdmin() && isValidPricingPlan(incoming());
    }
  }
}
